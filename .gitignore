# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
pip-wheel-metadata/

# ── Backend data (never commit) ───────────────────────────
backend/data/
backend/.env

# ── Node / frontend ───────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.local
.npm

# ── Rust / Cargo ──────────────────────────────────────────
target/
# Cargo.lock IS committed for this application crate (locks CI to exact local versions)
**/*.rs.bk

# ── Tauri build output ────────────────────────────────────
src-tauri/target/
# PyInstaller bundle
src-tauri/binaries/
# Generated zip -- do not commit large binary
src-tauri/resources/

# ── PyInstaller output ────────────────────────────────────
backend/dist/
backend/build-tmp/

# ── OS ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Claude Code ───────────────────────────────────────────
.claude/

# ── Editor ────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Env files (keep .example, never keep real) ────────────
.env
.env.*
!.env.example

# -- Dev / debug artefacts (generated locally, never commit) --
capture_frame.py
capture_window.py
make_gif.py
gif_frames/
restart_backend.bat
tauri-build-log.txt
backend/build-log.txt
frontend/dev-log.txt
backend/backend.pid
mimir.db
backend/build/

# -- Stray pip install artefacts (e.g. pip install "pkg>=x.y" without quotes
#    creates files named "=x.y" in CWD)
backend/=*
